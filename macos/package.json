{
  "name": "buhchat",
  "version": "1.0.0",
  "description": "BuhChat — корпоративный мессенджер (macOS)",
  "main": "main.js",
  "author": "BuhChat",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "dist": "npm run build:web && electron-builder --mac --arm64 --publish never",
    "build:web": "cd ../web && npm run build:desktop && rm -rf ../macos/app && cp -r dist ../macos/app"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.buhchat.app",
    "productName": "BuhChat",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.social-networking",
      "target": [
        "dmg"
      ],
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "directories": {
      "output": "dist"
    }
  }
}