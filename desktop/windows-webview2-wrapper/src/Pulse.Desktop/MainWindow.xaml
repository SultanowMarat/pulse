<Window x:Class="Pulse.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        MinWidth="1024"
        MinHeight="700"
        Width="1366"
        Height="820"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
  <Grid Background="#111827">
    <wv2:WebView2 x:Name="Browser" />

    <Border x:Name="LoadingOverlay"
            Background="#C0000000"
            Visibility="Collapsed">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="360">
        <TextBlock x:Name="LoadingText"
                   Text="Loading..."
                   Foreground="White"
                   FontSize="18"
                   Margin="0,0,0,14"
                   TextAlignment="Center" />
        <ProgressBar IsIndeterminate="True"
                     Height="8" />
      </StackPanel>
    </Border>

    <Border x:Name="ErrorOverlay"
            Width="520"
            MaxWidth="640"
            Padding="20"
            Background="#EE1F2937"
            BorderBrush="#334155"
            BorderThickness="1"
            CornerRadius="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed">
      <StackPanel>
        <TextBlock x:Name="ErrorTitle"
                   Text="Loading Error"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,8" />
        <TextBlock x:Name="ErrorDetails"
                   TextWrapping="Wrap"
                   Foreground="#D1D5DB"
                   Margin="0,0,0,16" />
        <StackPanel Orientation="Horizontal">
          <Button Content="Retry"
                  Click="RetryButton_Click"
                  MinWidth="120"
                  Height="36" />
          <Button Content="Open Start URL"
                  Click="OpenStartUrlButton_Click"
                  Margin="12,0,0,0"
                  MinWidth="180"
                  Height="36" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>
